# 钉钉群机器人Webhook URL（必填）
DINGDING_WEBHOOK=https://oapi.dingtalk.com/sendmsg?access_token=YOUR_TOKEN_HERE

# 钉钉签名密钥（可选，如启用加签验证）
# DINGDING_SECRET=YOUR_SECRET_HERE

# 阿里云OSS配置（可选，用于上传图表）
# OSS_ACCESS_KEY_ID=YOUR_ACCESS_KEY_ID
# OSS_ACCESS_KEY_SECRET=YOUR_ACCESS_KEY_SECRET
# OSS_BUCKET_NAME=YOUR_BUCKET_NAME
# OSS_ENDPOINT=oss-cn-shanghai.aliyuncs.com
# OSS_PREFIX=stock-charts/

# 说明：
# - DINGDING_WEBHOOK: 必填，钉钉群机器人的Webhook地址
# - DINGDING_SECRET: 可选，用于加签验证（提高安全性）
# - OSS_*: 可选，用于上传图表图片到阿里云OSS